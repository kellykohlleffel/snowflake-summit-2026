{
  "hosting": {
    "target": "activation-demo",
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "database": "activation-demo",
    "rules": "firestore.rules"
  }
}
