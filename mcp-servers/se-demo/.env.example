# se-demo MCP Server — Environment Configuration
#
# On lab laptops: populated by setup.sh from 1Password at install time.
# On Kelly's dev laptop: minimal subset required for dev flow; others are optional.
# See /Users/kelly.kohlleffel/.claude/plans/ok-now-let-s-playful-pine.md for full context.

# --- Lab laptop identity (lab laptops only; unset on Kelly's dev laptop) ---
# LABUSER_NUM         — 1..7, picked at setup.sh invocation (./setup.sh <N>)
# HOL_INSTRUCTOR      — "true" only on labuser-7 laptop; gates cleanup in SKILL.md
# LAPTOP_ID           — laptop{N} for activation app per-laptop namespacing
LABUSER_NUM=
HOL_INSTRUCTOR=false
LAPTOP_ID=

# --- Snowflake connection ---
# SNOWFLAKE_PAT       — Programmatic Access Token (preferred for lab laptops)
# SNOWFLAKE_PASSWORD  — kept for backward compat with Kelly's dev flow
# Set exactly one.
SNOWFLAKE_ACCOUNT=your_account_locator
SNOWFLAKE_USER=your_username
SNOWFLAKE_PAT=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_AUTH_TYPE=pat
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=SF_LAB_WH
SNOWFLAKE_DATABASE=HOL_DATABASE_1

# Snowflake RSA key (Kelly's dev flow — key-pair auth). Lab laptops leave unset.
SNOWFLAKE_PRIVATE_KEY_PATH=~/.snowflake/dbt_rsa_key.p8

# --- dbt ---
# DBT_PROFILE_TARGET  — "dev" (Kelly's flow, default) or "lab" (lab laptops).
#                       Controls which target block in profiles.yml is used.
# Other DBT_* values are auto-filled by setup.sh.
DBT_PROFILE_TARGET=dev
DBT_PATH=/path/to/venv/bin/dbt
DBT_PROJECT_DIR=/path/to/dbt_project
DBT_PROFILES_DIR=/path/to/dbt_project

# --- Fivetran API (for cleanup_demo connector lookup) ---
FIVETRAN_API_KEY=your_fivetran_api_key
FIVETRAN_API_SECRET=your_fivetran_api_secret
FIVETRAN_GROUP_ID=verbatim_suite

# --- Activation API ---
# Lab laptops will use fivetran-activation-api-v2 (per-laptop namespacing).
# Kelly's dev flow continues to use the v1 URL below.
ACTIVATION_API_URL=https://fivetran-activation-api-81810785507.us-central1.run.app

# --- PostgreSQL source (shared across all 7 labusers + Kelly's dev flow) ---
# Moved here from SKILL.md so the skill references these via env rather than
# hardcoding credentials in the skill body.
PG_HOL_HOST=34.94.122.157
PG_HOL_PORT=5432
PG_HOL_DATABASE=industry-se-demo
PG_HOL_USER=fivetran
PG_HOL_PASSWORD=
